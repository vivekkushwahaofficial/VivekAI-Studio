# ==============================================================================
# VivekAI Studio Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit '.env' to version control!
# ==============================================================================

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_workspace
DB_USER=ai_user
DB_PASSWORD=ai_password

# pgAdmin configuration (Local Docker dev only)
PGADMIN_EMAIL=admin@workspace.com
PGADMIN_PASSWORD=admin_password

# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080

# JWT Security Configurations
# Secret must be a base64-encoded string (min 256 bits / 32 bytes)
JWT_SECRET=replace_with_secure_secret_at_least_256_bits_long
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Local AI Provider (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
